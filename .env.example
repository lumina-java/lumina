APP_NAME=Lumina
APP_ENV=local
APP_KEY=base64:random_key_here
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=sqlite
DATABASE_URL=sqlite:database/database.sqlite
