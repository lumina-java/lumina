# DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/lumina

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

SESSION_DRIVER=database
CACHE_DRIVER=file
